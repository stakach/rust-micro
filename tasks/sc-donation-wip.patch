+/// Move scheduling context `sc_idx` to thread `to`. Mirrors upstream
+/// `schedContext_donate`: the previous owner (if any) loses the SC and
+/// becomes passive — it is dequeued from its ready queue and gives up
+/// the CPU if it was current — then `to` becomes the new owner. The
+/// caller is responsible for (re)scheduling `to` afterwards (e.g. via
+/// `make_runnable`, which now enqueues only once `to.sc` is set).
+///
+/// Used for Call-time donation to a passive server and for returning
+/// the SC to the caller on Reply.
+pub fn sc_donate(s: &mut crate::kernel::KernelState, sc_idx: usize, to: TcbId) {
+    let prev = s.sched_contexts[sc_idx].bound_tcb;
+    if let Some(from) = prev {
+        if from == to {
+            return;
+        }
+        // Previous owner becomes passive: remove from its ready queue
+        // (dequeue self-guards on the enqueued flag) and drop the SC.
+        let cpu = s.scheduler.slab.get(from).affinity as usize;
+        s.scheduler.nodes[cpu].queues.dequeue(&mut s.scheduler.slab, from);
+        s.scheduler.slab.get_mut(from).sc = None;
+        // If it was running anywhere, surrender the CPU so the
+        // dispatcher reschedules.
+        for node in s.scheduler.nodes.iter_mut() {
+            if node.current == Some(from) {
+                node.current = None;
+            }
+        }
+    }
+    s.sched_contexts[sc_idx].bound_tcb = Some(to);
+    s.scheduler.slab.get_mut(to).sc = Some(sc_idx as u16);
+}
+
+/// On reply to a caller that donated its SC to a passive server,
+/// move the SC back to the caller (upstream `reply_pop`). The SC is
+/// currently owned by the server (the replier); `sc_donate` takes it
+/// off the server — making the server passive again, dequeued and no
+/// longer current — and gives it to `caller`, which the reply path
+/// then `make_runnable`s. No-op when the caller didn't donate, or
+/// already acquired another SC while blocked (upstream keeps the
+/// donated one with the server in that case).
+pub fn return_donated_sc(s: &mut crate::kernel::KernelState, caller: TcbId) {
+    let donated = s.scheduler.slab.get_mut(caller).donated_sc.take();
+    if let Some(sc) = donated {
+        if s.scheduler.slab.get(caller).sc.is_none() {
+            sc_donate(s, sc as usize, caller);
+        }
+    }
+}
